{
  "platform": "snovio",
  "name": "Snov.io",
  "signup_url": "https://snov.io/affiliate",
  "steps": [
    { "action": "navigate", "url": "https://snov.io/affiliate" },
    { "action": "screenshot", "name": "landing" },
    {
      "action": "click",
      "selector": "a:has-text('Join'), a:has-text('Sign up'), a:has-text('Become an affiliate'), a:has-text('Get started'), button:has-text('Join'), a[href*='signup'], a[href*='register'], a[href*='referral']",
      "optional": true,
      "wait_for_nav": true
    },
    { "action": "screenshot", "name": "after_cta" },
    {
      "action": "fill",
      "selector": "input[name='email'], input[type='email'], input[id='email'], input[placeholder*='email' i]",
      "value": "{email}"
    },
    {
      "action": "fill",
      "selector": "input[name='password'], input[type='password'], input[id='password']",
      "value": "{password}",
      "optional": true
    },
    {
      "action": "fill",
      "selector": "input[name='name'], input[name='full_name'], input[name='first_name'], input[placeholder*='name' i]",
      "value": "{name}",
      "optional": true
    },
    { "action": "screenshot", "name": "filled_form" },
    {
      "action": "click",
      "selector": "button[type='submit'], input[type='submit'], button:has-text('Sign up'), button:has-text('Create account'), button:has-text('Register'), [type='submit']"
    },
    { "action": "wait", "ms": 3000 },
    { "action": "screenshot", "name": "result" },
    { "action": "check_captcha" },
    { "action": "check_success", "indicators": ["dashboard", "welcome", "referral", "affiliate", "verify your email", "confirm your email"] }
  ]
}
