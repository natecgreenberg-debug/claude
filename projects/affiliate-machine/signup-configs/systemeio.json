{
  "platform": "systemeio",
  "name": "Systeme.io",
  "signup_url": "https://systeme.io/affiliate-program",
  "steps": [
    { "action": "navigate", "url": "https://systeme.io/affiliate-program" },
    { "action": "screenshot", "name": "landing" },
    {
      "action": "click",
      "selector": "a:has-text('Join the affiliate program'), a:has-text('Become an affiliate'), a:has-text('Join now'), button:has-text('Join'), a[href*='signup'], a[href*='register']",
      "optional": true,
      "wait_for_nav": true
    },
    { "action": "screenshot", "name": "after_cta" },
    {
      "action": "fill",
      "selector": "input[name='email'], input[type='email'], input[id='email'], input[placeholder*='email' i]",
      "value": "{email}"
    },
    {
      "action": "fill",
      "selector": "input[name='password'], input[type='password'], input[id='password']",
      "value": "{password}",
      "optional": true
    },
    { "action": "screenshot", "name": "filled_form" },
    {
      "action": "click",
      "selector": "button[type='submit'], input[type='submit'], button:has-text('Create'), button:has-text('Sign up'), button:has-text('Get started'), [type='submit']"
    },
    { "action": "wait", "ms": 3000 },
    { "action": "screenshot", "name": "result" },
    { "action": "check_captcha" },
    { "action": "check_success", "indicators": ["dashboard", "welcome", "affiliate", "verify your email", "check your inbox"] }
  ]
}
